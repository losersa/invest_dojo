# InvestDojo Python 服务环境变量模板
# 使用：cp .env.example .env

# ── 运行环境 ──
ENV=development
LOG_LEVEL=INFO
LOG_FORMAT=pretty              # pretty / json

# ── Supabase ──
# 主项目的 apps/server/.env 里已经有了 SUPABASE_SERVICE_ROLE_KEY
# 这里不要重复配，pydantic 会从上级读取
SUPABASE_URL=https://adqznqsciqtepzimcvsg.supabase.co

# ── Redis ──
REDIS_URL=redis://localhost:6379/0

# ── MinIO ──
MINIO_ENDPOINT=http://localhost:9000
MINIO_ROOT_USER=investdojo
MINIO_ROOT_PASSWORD=investdojo_dev_only
MINIO_BUCKET=investdojo
