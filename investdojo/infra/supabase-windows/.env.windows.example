# ═══════════════════════════════════════════════════════════════════
# InvestDojo · Supabase 自托管栈 · Windows 环境变量模板
# ═══════════════════════════════════════════════════════════════════
#
# 使用：
#   1. 把本文件复制为 .env（和 docker-compose.yml、docker-compose.override.yml 同级）
#   2. 所有 <...> 占位必须替换，不然启动会失败
#   3. 千万不要把真实 .env 提交到 git
#
# 生成密钥的方法（在 Mac 或 Linux）：
#   openssl rand -base64 32        # → JWT_SECRET 和 POSTGRES_PASSWORD
#   然后用 JWT_SECRET 去 https://supabase.com/docs/guides/self-hosting/docker
#   按说明签 anon / service_role 两个 JWT
# ═══════════════════════════════════════════════════════════════════

############################
# Postgres
############################
POSTGRES_HOST=db
POSTGRES_DB=postgres
POSTGRES_PORT=5432
# ⚠️ 必改：强密码（≥ 24 字符，大小写+数字+符号）
POSTGRES_PASSWORD=<CHANGE_ME_STRONG_PASSWORD>

############################
# JWT（anon / service_role 必须用这个 secret 签出来）
############################
# ⚠️ 必改：openssl rand -base64 32
JWT_SECRET=<CHANGE_ME_AT_LEAST_32_BYTES>
JWT_EXPIRY=3600

# ⚠️ 必改：用上面的 JWT_SECRET 签出来的两个 token
# Supabase 官方文档给了现成的生成脚本
ANON_KEY=<CHANGE_ME_ANON_JWT>
SERVICE_ROLE_KEY=<CHANGE_ME_SERVICE_ROLE_JWT>

############################
# 对外地址（Mac 访问 Windows 用的地址！重点！）
############################
# 假设你把 Windows 主机名改成了 investdojo，或者路由器给它绑了 192.168.1.50
# 三选一：
#   a) 用主机名（推荐）: http://investdojo.local:8000
#   b) 用固定 IP:       http://192.168.1.50:8000
#   c) 用 Tailscale:    http://investdojo-win.ts.net:8000
API_EXTERNAL_URL=http://investdojo.local:8000
SUPABASE_PUBLIC_URL=http://investdojo.local:8000
SITE_URL=http://localhost:3000

# 额外允许的前端 origin（Mac 上的 Next.js dev）
ADDITIONAL_REDIRECT_URLS=http://localhost:3000,http://127.0.0.1:3000

############################
# Supabase Studio 管理面板
############################
STUDIO_PORT=3000
# ⚠️ 必改：Studio 登录用
DASHBOARD_USERNAME=investdojo
DASHBOARD_PASSWORD=<CHANGE_ME_DASHBOARD_PASSWORD>
STUDIO_DEFAULT_ORGANIZATION=InvestDojo
STUDIO_DEFAULT_PROJECT=investdojo-local

############################
# Kong API 网关
############################
KONG_HTTP_PORT=8000
KONG_HTTPS_PORT=8443

############################
# Auth (GoTrue)
############################
# MVP 阶段：先关注册，等数据迁移完成后再开
DISABLE_SIGNUP=false
ENABLE_EMAIL_SIGNUP=true
ENABLE_EMAIL_AUTOCONFIRM=true
ENABLE_ANONYMOUS_USERS=false

# 邮件发送（本地开发可以留空，Auth 会用内置测试模式）
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_SENDER_NAME=InvestDojo
SMTP_ADMIN_EMAIL=admin@investdojo.local

############################
# Storage（走本地文件系统，数据在 E:\investdojo\data\storage）
############################
STORAGE_BACKEND=file
FILE_SIZE_LIMIT=52428800
GLOBAL_S3_BUCKET=stub
REGION=us-east-1

############################
# Realtime / Analytics / Functions（一般不用改）
############################
FUNCTIONS_VERIFY_JWT=false
LOGFLARE_LOGGER_BACKEND_API_KEY=<CHANGE_ME_OR_LEAVE>
LOGFLARE_API_KEY=<CHANGE_ME_OR_LEAVE>

############################
# Pooler (pgBouncer) — Supabase 新版自带
############################
POOLER_TENANT_ID=investdojo
POOLER_DEFAULT_POOL_SIZE=20
POOLER_MAX_CLIENT_CONN=100
POOLER_DB_POOL_SIZE=10
SECRET_KEY_BASE=<CHANGE_ME_RANDOM_64>
VAULT_ENC_KEY=<CHANGE_ME_RANDOM_32>
