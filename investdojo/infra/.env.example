# InvestDojo 本地开发环境变量
#
# 使用：复制为 .env（不会进 git）
#   cp .env.example .env
#
# MinIO 凭证（本地开发用，不得用于生产）
MINIO_ROOT_USER=investdojo
MINIO_ROOT_PASSWORD=investdojo_dev_only
MINIO_ENDPOINT=http://localhost:9000
MINIO_REGION=us-east-1
MINIO_BUCKET=investdojo

# Redis 连接
REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379

# Supabase（生产环境云端，本地也使用）
SUPABASE_URL=https://adqznqsciqtepzimcvsg.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=（放在 apps/server/.env，不在这里）
