# ═══════════════════════════════════════════════════════════════════
# InvestDojo · Supabase 精简栈 · 环境变量模板
# ═══════════════════════════════════════════════════════════════════
#
# 首次运行 ./scripts/up.sh（或 .\scripts\up.ps1）时会：
#   - 把本文件复制为 .env
#   - 自动生成 POSTGRES_PASSWORD / JWT_SECRET / ANON_KEY / SERVICE_ROLE_KEY
#
# 你只需要关心：API_EXTERNAL_URL / SITE_URL，其他默认就行
# ═══════════════════════════════════════════════════════════════════

# ── Postgres ────────────────────────────────────────────────────
POSTGRES_PASSWORD=<CHANGE_ME_STRONG_PASSWORD>
POSTGRES_PORT=5432

# ── JWT（所有 key 的签发密钥，必须强随机）────────────────────────
JWT_SECRET=<CHANGE_ME_AT_LEAST_32_BYTES>
JWT_EXPIRY=3600

# ── API Key（首次 up 时自动签，不需要手动填）─────────────────────
ANON_KEY=<CHANGE_ME_ANON_JWT>
SERVICE_ROLE_KEY=<CHANGE_ME_SERVICE_ROLE_JWT>

# ── Kong 网关端口 ───────────────────────────────────────────────
KONG_HTTP_PORT=8000

# ── 对外地址（Mac 端 SUPABASE_URL 用这个）────────────────────────
# Windows 部署时：http://investdojo.local:8000（或 http://<LAN-IP>:8000）
# Mac 部署时（本地开发）：http://localhost:8000
API_EXTERNAL_URL=http://investdojo.local:8000
SITE_URL=http://localhost:3000
ADDITIONAL_REDIRECT_URLS=http://localhost:3000,http://127.0.0.1:3000

# ── Auth 策略 ────────────────────────────────────────────────────
DISABLE_SIGNUP=false
ENABLE_EMAIL_SIGNUP=true
ENABLE_EMAIL_AUTOCONFIRM=true

# ── SMTP（本地开发留空；autoconfirm=true 时无需发邮件）────────────
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_ADMIN_EMAIL=admin@investdojo.local

# ── 数据目录（默认 ./data，Windows 建议改到 E 盘）─────────────────
# Windows 示例：DATA_DIR=E:/investdojo/data
DATA_DIR=./data
